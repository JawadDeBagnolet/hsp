<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.DossierEnChargeController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Dossiers"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavPlanning" text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCatalogue" text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavUtilisateurs" text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDemandes" text="Mes Demandes" onAction="#versDemandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal : layout deux colonnes -->
    <center>
        <HBox spacing="0" style="-fx-padding: 0;">

            <!-- Panneau gauche : liste des élèves -->
            <VBox spacing="0" style="-fx-background-color: rgba(15,23,42,0.95); -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 0 1 0 0;" prefWidth="260" minWidth="220">
                <VBox style="-fx-padding: 20 16 12 16; -fx-background-color: rgba(99,102,241,0.1);">
                    <Text text="Élèves" style="-fx-font-size: 16px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                    <Text text="Sélectionnez un élève" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                </VBox>
                <ListView fx:id="elevesListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #e2e8f0;" />
            </VBox>

            <!-- Panneau droit : dossier médical -->
            <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 30;">

                    <!-- En-tête élève sélectionné -->
                    <VBox spacing="4" style="-fx-background-color: rgba(99,102,241,0.12); -fx-padding: 18 22; -fx-background-radius: 12; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Label fx:id="labelNomEleve" text="Sélectionnez un élève"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;" />
                        <Label fx:id="labelInfoEleve" text=""
                               style="-fx-font-size: 13px; -fx-text-fill: #94a3b8;" />
                        <Label fx:id="labelDateCreation" text=""
                               style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-style: italic;" />
                    </VBox>

                    <!-- Formulaire dossier médical -->
                    <VBox spacing="16" style="-fx-background-color: rgba(248,250,252,0.97); -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Text text="Dossier Médical Permanent"
                              style="-fx-font-size: 17px; -fx-fill: #1e293b; -fx-font-weight: bold;" />
                        <Separator />

                        <!-- Antécédents médicaux -->
                        <VBox spacing="6">
                            <Label text="Antécédents médicaux"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                            <TextArea fx:id="antecedentsField"
                                      promptText="Ex : diabète de type 1, asthme, hypertension..."
                                      prefRowCount="3" wrapText="true"
                                      style="-fx-font-size: 13px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 1.5; -fx-border-radius: 5;" />
                        </VBox>

                        <!-- Allergies -->
                        <VBox spacing="6">
                            <Label text="Allergies connues"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #dc2626;" />
                            <TextArea fx:id="allergiesField"
                                      promptText="Ex : pénicilline, arachides, latex..."
                                      prefRowCount="3" wrapText="true"
                                      style="-fx-font-size: 13px; -fx-background-color: white; -fx-border-color: rgba(220,38,38,0.3); -fx-border-width: 1.5; -fx-border-radius: 5;" />
                        </VBox>

                        <!-- Traitements chroniques -->
                        <VBox spacing="6">
                            <Label text="Traitements chroniques"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0891b2;" />
                            <TextArea fx:id="traitementsField"
                                      promptText="Ex : Ventoline 2 bouffées matin et soir, Metformine 500mg..."
                                      prefRowCount="3" wrapText="true"
                                      style="-fx-font-size: 13px; -fx-background-color: white; -fx-border-color: rgba(8,145,178,0.3); -fx-border-width: 1.5; -fx-border-radius: 5;" />
                        </VBox>

                        <!-- Boutons + message -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="sauvegarderButton" text="Sauvegarder le dossier"
                                    onAction="#handleSauvegarder" disable="true"
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;" />
                            <Button fx:id="supprimerButton" text="Supprimer le dossier"
                                    onAction="#handleSupprimerDossier" disable="true"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 22; -fx-background-radius: 8; -fx-cursor: hand;" />
                            <Label fx:id="messageLabel" text=""
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>
                    </VBox>

                    <!-- Historique des visites -->
                    <VBox spacing="10" style="-fx-background-color: rgba(248,250,252,0.97); -fx-padding: 24; -fx-background-radius: 12; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 1; -fx-border-radius: 12;">
                        <Text text="Historique des visites à l'infirmerie"
                              style="-fx-font-size: 17px; -fx-fill: #1e293b; -fx-font-weight: bold;" />
                        <Separator />
                        <TableView fx:id="visitesTableView" prefHeight="250"
                                   style="-fx-background-color: white; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 1; -fx-border-radius: 5;">
                            <columns>
                                <TableColumn fx:id="colDate" text="Date" prefWidth="100" />
                                <TableColumn fx:id="colHeure" text="Heure" prefWidth="70" />
                                <TableColumn fx:id="colMotif" text="Motif" prefWidth="200" />
                                <TableColumn fx:id="colTraitement" text="Traitement" prefWidth="200" />
                                <TableColumn fx:id="colStatut" text="Statut" prefWidth="110" />
                            </columns>
                            <placeholder>
                                <Label text="Aucune visite enregistrée pour cet élève"
                                       style="-fx-text-fill: #94a3b8; -fx-font-style: italic;" />
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </HBox>
    </center>
</BorderPane>
