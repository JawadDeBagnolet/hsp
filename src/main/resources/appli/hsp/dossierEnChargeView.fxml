<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.DossierEnChargeController"
            style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #3498db);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15; -fx-border-color: #2c3e50; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            
            <!-- Logo/Titre -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="HSP" 
                      style="-fx-font-size: 24px; -fx-fill: #3498db; -fx-font-weight: bold;" />
                <Text text="Hôpital de Santé Publique" 
                      style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
            </VBox>
            
            <!-- Menu de navigation -->
            <HBox spacing="20" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versAccueil" />
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                
                <Button text="Patients"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versPatients" />
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                
                <Button text="Dossiers"
                        style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #2980b9; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" />
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                
                <Button text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versCommandes" />
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                
                <Button text="Utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versUtilisateurs" />
                
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                
                <Button text="Mon espace"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versMonEspace" />
                
                <Button text="Déconnexion"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #c0392b; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: linear-gradient(to bottom, #2c3e50, #3498db); -fx-border-color: transparent;">
            <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Titre de la page -->
                <VBox spacing="15" alignment="CENTER">
                    <Text text="🏥 Créer un Dossier de Prise en Charge"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                    
                    <Text text="Enregistrement d'un nouveau patient pour prise en charge"
                          style="-fx-font-size: 18px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />
                </VBox>

                <!-- Formulaire de création -->
                <VBox spacing="20" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 500;">
                    
                    <!-- Date d'arrivée -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Date d'arrivée *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <DatePicker fx:id="dateArriveeField" 
                                   editable="false"
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-opacity: 1;" />
                    </VBox>

                    <!-- Heure d'arrivée -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Heure d'arrivée *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <HBox spacing="10">
                            <ComboBox fx:id="heureCombo" 
                                     style="-fx-pref-width: 80; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-opacity: 1;" />
                            <Label text=":" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            <ComboBox fx:id="minuteCombo" 
                                     style="-fx-pref-width: 80; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-opacity: 1;" />
                        </HBox>
                    </VBox>

                    <!-- Symptômes -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Symptômes *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <TextArea fx:id="symptomesField" 
                                 promptText="Décrivez les symptômes du patient..."
                                 prefRowCount="4"
                                 wrapText="true"
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <!-- Niveau de gravité -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Niveau de gravité *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <ComboBox fx:id="niveauGraviteCombo" 
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-opacity: 1;" />
                    </VBox>

                    <!-- Patient -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Patient *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <ComboBox fx:id="patientCombo" 
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #2c3e50; -fx-opacity: 1;" />
                    </VBox>

                <!-- Barre de recherche et boutons d'action -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                    <TextField fx:id="rechercheField" 
                              promptText="🔍 Rechercher par symptômes, date ou niveau de gravité..."
                              style="-fx-pref-width: 400; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 2; -fx-border-radius: 5;" />
                    
                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="nouveauButton" 
                                text="🆕 Nouveau" 
                                onAction="#handleNouveauDossier"
                                style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                        
                        <Button fx:id="modifierButton" 
                                text="✏️ Modifier" 
                                onAction="#handleModifierDossier"
                                disable="true"
                                style="-fx-background-color: #f39c12; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                        
                        <Button fx:id="supprimerButton" 
                                text="🗑️ Supprimer" 
                                onAction="#handleSupprimerDossier"
                                disable="true"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                    </HBox>
                </HBox>

                <!-- Message de statut -->
                <Label fx:id="messageLabel" 
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />

                    <!-- Boutons d'action -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="✅ Créer le dossier" 
                                onAction="#handleCreerDossier"
                                style="-fx-background-color: #27ae60; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 180;" />
                        
                        <Button text="🔄 Vider les champs" 
                                onAction="#handleViderChamps"
                                style="-fx-background-color: #f39c12; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 180;" />
                    </HBox>
                </VBox>

                <!-- Bouton de retour -->
                <HBox spacing="20" alignment="CENTER">
                    <Button text="🏠 Retour à l'accueil" onAction="#handleRetour" 
                            style="-fx-background-color: #95a5a6; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 30; -fx-background-radius: 25; -fx-cursor: hand;" />
                </HBox>
                
                <!-- Liste des dossiers existants -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.95); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 700;">
                    <Text text="📋 Liste des Dossiers de Prise en Charge"
                          style="-fx-font-size: 20px; -fx-fill: #2c3e50; -fx-font-weight: bold;" />
                    
                    <Separator style="-fx-background-color: #bdc3c7; -fx-pref-width: 100%;" />
                    
                    <Text text="💡 Cliquez sur un dossier pour le visualiser, puis utilisez les boutons Modifier/Supprimer"
                          style="-fx-font-size: 12px; -fx-fill: #7f8c8d; -fx-font-style: italic;" />
                    
                    <ScrollPane fitToWidth="true" fitToHeight="true" prefHeight="300" 
                               style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <ListView fx:id="dossiersListView" 
                                 style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-border-radius: 5; -fx-font-size: 14px;" />
                    </ScrollPane>
                </VBox>
                
                <!-- Espace supplémentaire pour s'assurer que le défilement fonctionne -->
                <VBox style="-fx-pref-height: 100;">
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
