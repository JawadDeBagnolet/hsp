<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.DossierEnChargeController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Dossiers"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavPlanning" text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCatalogue" text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavUtilisateurs" text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDemandes" text="Mes Demandes" onAction="#versDemandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Titre de la page -->
                <VBox spacing="15" alignment="CENTER">
                    <Text text="📋 Dossier Infirmerie"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />

                    <Text text="Compte rendu de passage d'un élève"
                          style="-fx-font-size: 18px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />
                </VBox>

                <!-- Formulaire de création -->
                <VBox spacing="20" alignment="CENTER" style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 500;">
                    
                    <!-- Date d'arrivée -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Date d'arrivée *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <DatePicker fx:id="dateArriveeField" 
                                   editable="false"
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-opacity: 1;" />
                    </VBox>

                    <!-- Heure d'arrivée -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Heure d'arrivée *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <HBox spacing="10">
                            <ComboBox fx:id="heureCombo" 
                                     style="-fx-pref-width: 80; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #1e293b; -fx-opacity: 1;" />
                            <Label text=":" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                            <ComboBox fx:id="minuteCombo" 
                                     style="-fx-pref-width: 80; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #1e293b; -fx-opacity: 1;" />
                        </HBox>
                    </VBox>

                    <!-- Symptômes -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Symptômes *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextArea fx:id="symptomesField"
                                 promptText="Décrivez les symptômes de l'élève..."
                                 prefRowCount="4"
                                 wrapText="true"
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <!-- Niveau de gravité -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Niveau de gravité *" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <ComboBox fx:id="niveauGraviteCombo" 
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #1e293b; -fx-opacity: 1;" />
                    </VBox>

                    <!-- Patient -->
                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Élève *"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <ComboBox fx:id="patientCombo" 
                                 style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5; -fx-cursor: hand; -fx-text-fill: #1e293b; -fx-opacity: 1;" />
                    </VBox>

                <!-- Boutons d'action -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button fx:id="nouveauButton" 
                                text="🆕 Nouveau" 
                                onAction="#handleNouveauDossier"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                        
                        <Button fx:id="modifierButton" 
                                text="✏️ Modifier" 
                                onAction="#handleModifierDossier"
                                disable="true"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                        
                        <Button fx:id="supprimerButton" 
                                text="🗑️ Supprimer" 
                                onAction="#handleSupprimerDossier"
                                disable="true"
                                style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand;" />
                    </HBox>

                    <!-- Message de statut -->
                    <Label fx:id="messageLabel" 
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" />

                    <!-- Boutons d'action -->
                    <HBox spacing="15" alignment="CENTER">
                        <Button text="✅ Créer le dossier" 
                                onAction="#handleCreerDossier"
                                style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 180;" />
                        
                        <Button text="🔄 Vider les champs" 
                                onAction="#handleViderChamps"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 180;" />
                    </HBox>
                </VBox>

                <!-- Bouton de retour -->
                <HBox spacing="20" alignment="CENTER">
                    <Button text="🏠 Retour à l'accueil" onAction="#handleRetour" 
                            style="-fx-background-color: #64748b; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 30; -fx-background-radius: 25; -fx-cursor: hand;" />
                </HBox>
                
                <!-- Liste des dossiers existants -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 700;">
                    <Text text="📋 Liste des Dossiers de Prise en Charge"
                          style="-fx-font-size: 20px; -fx-fill: #1e293b; -fx-font-weight: bold;" />
                    
                    <Separator style="-fx-background-color: rgba(99,102,241,0.3); -fx-pref-width: 100%;" />
                    
                    <Text text="💡 Cliquez sur un dossier pour le visualiser, puis utilisez les boutons Modifier/Supprimer"
                          style="-fx-font-size: 12px; -fx-fill: #64748b; -fx-font-style: italic;" />
                    
                    <ScrollPane fitToWidth="true" fitToHeight="true" prefHeight="300" 
                               style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <ListView fx:id="dossiersListView" 
                                 style="-fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 1; -fx-border-radius: 5; -fx-font-size: 14px;" />
                    </ScrollPane>
                </VBox>
                
                <!-- Espace supplémentaire pour s'assurer que le défilement fonctionne -->
                <VBox style="-fx-pref-height: 100;">
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
