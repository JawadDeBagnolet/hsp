<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.FicheProduitController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDossiers" text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavPlanning" text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button fx:id="btnNavUtilisateurs" text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Titre -->
                <VBox spacing="10" alignment="CENTER">
                    <Text text="Catalogue des Produits"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                    <Text text="Gérer les produits disponibles pour les commandes"
                          style="-fx-font-size: 16px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />
                </VBox>

                <!-- Formulaire -->
                <VBox spacing="18" alignment="CENTER" style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 650;">

                    <Text text="Ajouter / Modifier un produit" style="-fx-font-size: 20px; -fx-fill: #1e293b; -fx-font-weight: bold;" />
                    <Separator style="-fx-pref-width: 100%;" />

                    <VBox spacing="6" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Libellé *" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextField fx:id="libelleField" promptText="Nom du produit..."
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <VBox spacing="6" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Description" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextArea fx:id="descriptionArea" promptText="Description du produit..." prefRowCount="3"
                                  style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;"
                                  wrapText="true" />
                    </VBox>

                    <VBox spacing="6" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Niveau de dangerosité (0 = faible, 1 = moyen, 2 = élevé, 3 = critique)"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextField fx:id="dangerositéField" promptText="0, 1, 2 ou 3"
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <Label fx:id="messageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" />

                    <HBox spacing="12" alignment="CENTER">
                        <Button text="Ajouter" onAction="#handleAjouter"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 130;" />
                        <Button text="Modifier" onAction="#handleModifier"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 130;" />
                        <Button text="Supprimer" onAction="#handleSupprimer"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 130;" />
                        <Button text="Vider" onAction="#handleVider"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-pref-width: 130;" />
                    </HBox>
                </VBox>

                <!-- Liste des produits -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 800;">
                    <Text text="Produits enregistrés" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Separator style="-fx-background-color: rgba(99, 102, 241, 0.2); -fx-pref-width: 100%;" />

                    <!-- Bannière alerte stock faible -->
                    <Label fx:id="alerteStockLabel"
                           style="-fx-background-color: #7f1d1d; -fx-text-fill: #fca5a5; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 8; -fx-pref-width: 100%;"
                           visible="false" managed="false" />

                    <Label text="Cliquez sur un produit pour le modifier ou le supprimer"
                           style="-fx-font-size: 13px; -fx-font-style: italic; -fx-text-fill: #ecf0f1;" />
                    <ListView fx:id="produitsListView" prefHeight="350"
                              style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10; -fx-pref-width: 100%;" />
                </VBox>

                <VBox style="-fx-pref-height: 50;" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
