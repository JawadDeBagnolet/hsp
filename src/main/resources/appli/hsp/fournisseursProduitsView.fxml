<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="appli.hsp.FournisseursProduitsController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Retour à l'accueil" onAction="#handleRetour"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox spacing="25" style="-fx-padding: 40;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Titre -->
                <VBox spacing="10" alignment="CENTER">
                    <Text text="Fournisseurs Produits"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                    <Text text="Gestion des associations fournisseurs / produits"
                          style="-fx-font-size: 16px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />
                </VBox>

                <!-- Actions -->
                <HBox spacing="15" alignment="CENTER_LEFT"
                      style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 15 20; -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10;">
                    <Button text="➕ Nouveau fournisseur produit" onAction="#handleNouveauFournisseurProduit"
                            style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button text="🔄 Rafraîchir" onAction="#handleRafraichir"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Pane HBox.hgrow="ALWAYS" />
                    <Label fx:id="messageLabel" text=""
                           style="-fx-font-weight: bold; -fx-text-fill: #ecf0f1; -fx-font-size: 13px;" />
                </HBox>

                <!-- Tableau -->
                <VBox spacing="10"
                      style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10;">
                    <Text text="Liste des fournisseurs produits"
                          style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />

                    <TableView fx:id="fournisseursProduitsTable" prefHeight="500" minHeight="300" maxHeight="Infinity" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-radius: 6; -fx-background-radius: 6;">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="80" text="ID" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="fournisseurColumn" prefWidth="120" text="ID Fournisseur" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="produitColumn" prefWidth="120" text="ID Produit" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="prixColumn" prefWidth="100" text="Prix" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="actionsColumn" prefWidth="150" text="Actions" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox style="-fx-pref-height: 50;" />
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
