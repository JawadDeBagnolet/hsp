<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="appli.hsp.FournisseursProduitsController"
      spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #f5f7fa; -fx-padding: 20;">

    <!-- Header -->
    <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 15; -fx-background-radius: 8;">
        <Button text="🏠 Accueil" onAction="#handleRetour"
                style="-fx-background-color: #3498db; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-pref-width: 100; -fx-pref-height: 35; -fx-background-radius: 5;" />
        <Text text="🏭 Gestion des Fournisseurs Produits" style="-fx-fill: #e8e8e8; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <Pane HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Main Content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 8;">
        <VBox spacing="25" style="-fx-padding: 30; -fx-background-radius: 8;">
            <Text text="Liste des fournisseurs produits" style="-fx-font-size: 16px; -fx-fill: #2c3e50; -fx-font-weight: bold;" />

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Nouveau fournisseur produit" onAction="#handleNouveauFournisseurProduit"
                        style="-fx-background-color: #27ae60; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-pref-width: 200; -fx-pref-height: 35; -fx-background-radius: 5;" />
                <Button text="Rafraîchir" onAction="#handleRafraichir"
                        style="-fx-background-color: #4a4a6a; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-pref-width: 120; -fx-pref-height: 35; -fx-background-radius: 5;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="messageLabel" text="" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
            </HBox>

            <TableView fx:id="fournisseursProduitsTable" prefHeight="500" minHeight="300" maxHeight="Infinity" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6;">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="80" text="ID" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                    <TableColumn fx:id="fournisseurColumn" prefWidth="120" text="ID Fournisseur" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                    <TableColumn fx:id="produitColumn" prefWidth="120" text="ID Produit" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                    <TableColumn fx:id="prixColumn" prefWidth="100" text="Prix" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                    <TableColumn fx:id="actionsColumn" prefWidth="150" text="Actions" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </ScrollPane>
</VBox>
