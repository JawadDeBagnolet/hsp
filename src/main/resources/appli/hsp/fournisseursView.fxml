<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.FournisseursController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Navbar -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDossiers" text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Fournisseurs"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button fx:id="btnNavUtilisateurs" text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Titre -->
            <VBox spacing="4" alignment="CENTER">
                <Text text="Gestion des Fournisseurs"
                      style="-fx-font-size: 30px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                <Label fx:id="messageLabel" style="-fx-font-size: 13px; -fx-font-weight: bold;" />
            </VBox>

            <!-- Formulaire ajout / édition -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(248,250,252,0.06); -fx-padding: 18; -fx-background-radius: 12; -fx-border-color: rgba(99,102,241,0.25); -fx-border-width: 1; -fx-border-radius: 12;">
                <TextField fx:id="nomFournisseurField" promptText="Nom du fournisseur"
                           style="-fx-pref-width: 200; -fx-font-size: 13px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(99,102,241,0.4); -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" />
                <TextField fx:id="emailFournisseurField" promptText="Email"
                           style="-fx-pref-width: 200; -fx-font-size: 13px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(99,102,241,0.4); -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" />
                <TextField fx:id="telephoneFournisseurField" promptText="Téléphone"
                           style="-fx-pref-width: 150; -fx-font-size: 13px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(99,102,241,0.4); -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;" />
                <Button fx:id="btnAjouter" text="Ajouter le fournisseur" onAction="#handleAjouterFournisseur"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Annuler" onAction="#handleViderChamps"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 14;" />
            </HBox>

            <!-- Deux tableaux côte à côte -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <!-- Tableau fournisseurs -->
                <VBox spacing="10" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Text text="Liste des fournisseurs"
                          style="-fx-font-size: 16px; -fx-fill: #a78bfa; -fx-font-weight: bold;" />
                    <TableView fx:id="fournisseursTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: rgba(15,23,42,0.9); -fx-background-radius: 10; -fx-border-color: rgba(99,102,241,0.3); -fx-border-radius: 10; -fx-border-width: 1; -fx-table-cell-border-color: rgba(99,102,241,0.1);">
                        <columns>
                            <TableColumn fx:id="colNom" text="Nom"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colEmail" text="Email"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colTel" text="Téléphone" prefWidth="120"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colActions" text="Actions" prefWidth="160"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                        </columns>
                        <placeholder>
                            <Label text="Aucun fournisseur enregistré" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- Panneau produits du fournisseur sélectionné -->
                <VBox spacing="10" prefWidth="420" VBox.vgrow="ALWAYS">
                    <Label fx:id="fournisseurSelectionneLabel" text="Sélectionnez un fournisseur"
                           style="-fx-text-fill: #22d3ee; -fx-font-size: 16px; -fx-font-weight: bold;" />

                    <!-- Formulaire ajout produit -->
                    <VBox fx:id="formProduitBox" spacing="8" managed="false" visible="false"
                          style="-fx-background-color: rgba(34,211,238,0.06); -fx-padding: 12; -fx-background-radius: 10; -fx-border-color: rgba(34,211,238,0.25); -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label fx:id="messageProduitLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                        <HBox spacing="8">
                            <TextField fx:id="nomProduitField" promptText="Nom du produit" HBox.hgrow="ALWAYS"
                                       style="-fx-font-size: 12px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(34,211,238,0.4); -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 6;" />
                            <TextField fx:id="descProduitField" promptText="Description" prefWidth="100"
                                       style="-fx-font-size: 12px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(34,211,238,0.4); -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 6;" />
                        </HBox>
                        <HBox spacing="8">
                            <TextField fx:id="prixProduitField" promptText="Prix (€)" prefWidth="100"
                                       style="-fx-font-size: 12px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(34,211,238,0.4); -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 6;" />
                            <TextField fx:id="quantiteProduitField" promptText="Quantité" prefWidth="90"
                                       style="-fx-font-size: 12px; -fx-background-color: #1e293b; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-border-color: rgba(34,211,238,0.4); -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 6;" />
                            <Button fx:id="btnAjouterProduit" text="Ajouter" onAction="#handleAjouterProduit"
                                    style="-fx-background-color: #22d3ee; -fx-text-fill: #0f172a; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 12;" />
                            <Button text="Annuler" onAction="#handleAnnulerProduit"
                                    style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 10;" />
                        </HBox>
                    </VBox>

                    <!-- Bouton afficher formulaire -->
                    <Button fx:id="btnNouveauProduit" text="+ Ajouter un produit" onAction="#handleNouveauProduit"
                            managed="false" visible="false"
                            style="-fx-background-color: rgba(34,211,238,0.15); -fx-text-fill: #22d3ee; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: rgba(34,211,238,0.4); -fx-border-width: 1; -fx-border-radius: 8; -fx-cursor: hand; -fx-padding: 7 16;" />

                    <TableView fx:id="produitsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: rgba(15,23,42,0.9); -fx-background-radius: 10; -fx-border-color: rgba(34,211,238,0.3); -fx-border-radius: 10; -fx-border-width: 1; -fx-table-cell-border-color: rgba(34,211,238,0.1);">
                        <columns>
                            <TableColumn fx:id="colProduitNom" text="Produit"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colProduitPrix" text="Prix (€)" prefWidth="70"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colProduitQuantite" text="Qté" prefWidth="50"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                            <TableColumn fx:id="colProduitActions" text="Actions" prefWidth="140"
                                         style="-fx-text-fill: #e2e8f0; -fx-font-weight: bold; -fx-background-color: #1e293b;" />
                        </columns>
                        <placeholder>
                            <Label text="Aucun produit pour ce fournisseur" style="-fx-text-fill: #64748b; -fx-font-size: 13px;" />
                        </placeholder>
                    </TableView>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>
