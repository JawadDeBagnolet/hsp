<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.FournisseursController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Fournisseurs"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Titre -->
                <VBox spacing="15" alignment="CENTER">
                    <Text text="Gestion des Fournisseurs"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                    <Text text="Ajouter des fournisseurs et gérer leurs produits"
                          style="-fx-font-size: 18px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />
                </VBox>

                <!-- Formulaire d'ajout de fournisseur -->
                <VBox spacing="20" alignment="CENTER" style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 600;">

                    <Text text="Ajouter un Fournisseur" style="-fx-font-size: 20px; -fx-fill: #1e293b; -fx-font-weight: bold;" />
                    <Separator style="-fx-pref-width: 100%;" />

                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Nom du fournisseur *" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextField fx:id="nomFournisseurField" promptText="Entrez le nom du fournisseur..."
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Email *" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextField fx:id="emailFournisseurField" promptText="Entrez l'email du fournisseur..."
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-pref-width: 100%;">
                        <Label text="Téléphone *" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
                        <TextField fx:id="telephoneFournisseurField" promptText="Entrez le numéro de téléphone..."
                                   style="-fx-pref-width: 100%; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: rgba(99,102,241,0.3); -fx-border-width: 2; -fx-border-radius: 5;" />
                    </VBox>

                    <Label fx:id="messageLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" />

                    <HBox spacing="15" alignment="CENTER">
                        <Button text="Ajouter le fournisseur" onAction="#handleAjouterFournisseur"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 200;" />
                        <Button text="Vider les champs" onAction="#handleViderChamps"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-pref-width: 200;" />
                    </HBox>
                </VBox>

                <!-- Liste des fournisseurs -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 800;">
                    <Text text="Liste des Fournisseurs" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Separator style="-fx-background-color: rgba(99, 102, 241, 0.2); -fx-pref-width: 100%;" />
                    <ListView fx:id="fournisseursListView" prefHeight="300"
                              style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10; -fx-pref-width: 100%;" />
                </VBox>

                <!-- Section produits du fournisseur -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 800;">
                    <Text text="Produits du Fournisseur" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Separator style="-fx-background-color: rgba(99, 102, 241, 0.2); -fx-pref-width: 100%;" />
                    <Label fx:id="fournisseurSelectionneLabel" text="Veuillez sélectionner un fournisseur pour voir ses produits"
                           style="-fx-font-size: 14px; -fx-font-style: italic; -fx-text-fill: #ecf0f1;" />
                    <ListView fx:id="produitsListView" prefHeight="250"
                              style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10; -fx-pref-width: 100%;" />
                </VBox>

                <VBox style="-fx-pref-height: 100;" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
