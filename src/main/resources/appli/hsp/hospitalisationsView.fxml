<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="appli.hsp.HospitalisationsController"
            style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #3498db);">

    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15; -fx-border-color: #2c3e50; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="HSP" style="-fx-font-size: 24px; -fx-fill: #3498db; -fx-font-weight: bold;" />
                <Text text="Hospitalisations" style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
            </VBox>

            <HBox spacing="20" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versAccueil" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Patients"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versPatients" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Dossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versDossiers" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versCommandes" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Hospitalisations"
                        style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #2980b9; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versUtilisateurs" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Mon espace"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versMonEspace" />

                <Button text="Déconnexion"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #c0392b; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 30;">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="30" />
                </padding>

                <VBox spacing="25" style="-fx-background-color: #2d2d3d; -fx-padding: 30; -fx-background-radius: 10; -fx-border-color: #404050; -fx-border-width: 1;">
                    <Text text="🏥 Gestion des hospitalisations" style="-fx-font-size: 18px; -fx-fill: #e8e8e8; -fx-font-weight: bold;" />

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Button text="Nouvelle hospitalisation" onAction="#handleNouvelleHospitalisation"
                                style="-fx-background-color: #27ae60; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-pref-width: 180; -fx-pref-height: 35; -fx-background-radius: 5;" />
                        <Button text="Rafraîchir" onAction="#handleRafraichir"
                                style="-fx-background-color: #4a4a6a; -fx-text-fill: #e8e8e8; -fx-font-size: 14px; -fx-pref-width: 120; -fx-pref-height: 35; -fx-background-radius: 5;" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="messageLabel" text="" style="-fx-font-weight: bold; -fx-text-fill: #e8e8e8;" />
                    </HBox>

                    <TableView fx:id="hospitalisationsTable" prefHeight="500" minHeight="300" maxHeight="Infinity" VBox.vgrow="ALWAYS" style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6;">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="60" text="ID" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="dossierColumn" prefWidth="80" text="Dossier" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="chambreColumn" prefWidth="120" text="Chambre" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="debutColumn" prefWidth="160" text="Date début" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="finColumn" prefWidth="160" text="Date fin" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="descriptionColumn" prefWidth="250" text="Description" style="-fx-font-weight: bold;" />
                            <TableColumn fx:id="actionsColumn" prefWidth="140" text="Actions" style="-fx-font-weight: bold; -fx-alignment: CENTER;" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
