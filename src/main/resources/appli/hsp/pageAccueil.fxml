<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.PageAccueil"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;"
                        onAction="#versAccueil" />
                <Button text="Secrétariat"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versPatients" />
                <Button text="Dossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versDossiers" />
                <Button text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versCommandes" />
                <Button text="Planning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versPlanning" />
                <Button text="Catalogue"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versFicheProduit" />
                <Button text="Utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"
                        onAction="#versUtilisateurs" />
                <Button text="Mon espace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;"
                        onAction="#versMonEspace" />
                <Button text="Déconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="50" style="-fx-padding: 60 80;">

                <!-- Header -->
                <VBox spacing="10" alignment="CENTER">
                    <Text text="Tableau de bord"
                          style="-fx-font-size: 42px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Bienvenue dans votre espace de travail"
                          style="-fx-font-size: 16px; -fx-fill: #94a3b8;" />
                </VBox>

                <!-- Ligne 1 : 5 modules -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Secrétariat -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(59,130,246,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(59,130,246,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Secrétariat" style="-fx-font-size: 18px; -fx-fill: #60a5fa; -fx-font-weight: bold;" />
                        <Text text="Inscription élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versPatients"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Planning -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(245,158,11,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(245,158,11,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Planning" style="-fx-font-size: 18px; -fx-fill: #fbbf24; -fx-font-weight: bold;" />
                        <Text text="RDV profs / élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Voir" onAction="#versPlanning"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Infirmerie -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(239,68,68,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(239,68,68,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Infirmerie" style="-fx-font-size: 18px; -fx-fill: #f87171; -fx-font-weight: bold;" />
                        <Text text="Visites élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versVisiteInfirmerie"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Commandes -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(16,185,129,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(16,185,129,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Commandes" style="-fx-font-size: 18px; -fx-fill: #34d399; -fx-font-weight: bold;" />
                        <Text text="Fournisseurs" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versCommandes"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Fournisseurs -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(139,92,246,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(139,92,246,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Fournisseurs" style="-fx-font-size: 18px; -fx-fill: #a78bfa; -fx-font-weight: bold;" />
                        <Text text="Stock / Produits" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="fournisseursButton" text="Gérer" onAction="#versFournisseursProduits"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                </HBox>

                <!-- Ligne 2 : 1 module -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Catalogue -->
                    <VBox spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(6,182,212,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(6,182,212,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Catalogue" style="-fx-font-size: 18px; -fx-fill: #22d3ee; -fx-font-weight: bold;" />
                        <Text text="Produits commandables" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versFicheProduit"
                                style="-fx-background-color: #06b6d4; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                </HBox>

                <!-- Footer -->
                <VBox spacing="4" alignment="CENTER">
                    <Text text="Version 1.0 · 2025" style="-fx-font-size: 12px; -fx-fill: #334155;" />
                    <Text text="© LPRS - Lycée de Santé Publique" style="-fx-font-size: 12px; -fx-fill: #334155;" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
