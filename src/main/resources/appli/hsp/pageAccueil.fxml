<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.PageAccueil"
            style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #3498db);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15; -fx-border-color: #2c3e50; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- Logo/Titre -->
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="HSP"
                      style="-fx-font-size: 24px; -fx-fill: #3498db; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique"
                      style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
            </VBox>

            <!-- Menu de navigation -->
            <HBox spacing="20" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versAccueil" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Secrétariat"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versPatients" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Dossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versDossiers" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versCommandes" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Planning"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versPlanning" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Catalogue"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versFicheProduit" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versUtilisateurs" />

                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />

                <Button text="Mon espace"
                        style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #2980b9; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"
                        onAction="#versMonEspace" />

                <Button text="Déconnexion"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #c0392b; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <VBox alignment="CENTER" spacing="40" style="-fx-padding: 60;">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Message de bienvenue -->
            <VBox spacing="15" alignment="CENTER">
                <Text text="Tableau de bord"
                      style="-fx-font-size: 48px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />

                <Text text="Bienvenue dans votre espace de travail"
                      style="-fx-font-size: 24px; -fx-fill: #ecf0f1; -fx-font-weight: 500;" />

                <Text text="Gérez efficacement votre établissement"
                      style="-fx-font-size: 18px; -fx-fill: #bdc3c7; -fx-font-style: italic;" />
            </VBox>

            <!-- Zone d'accès rapide - Ligne 1 -->
            <HBox spacing="30" alignment="CENTER">
                <!-- Carte Secrétariat -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Secrétariat" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Inscription élèves" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button text="Gérer" onAction="#versPatients"
                            style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>

                <!-- Carte Planning RDV -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Planning" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="RDV profs / élèves" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button text="Voir" onAction="#versPlanning"
                            style="-fx-background-color: #f39c12; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>

                <!-- Carte Visites Infirmerie -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Infirmerie" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Visites élèves" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button text="Gérer" onAction="#versVisiteInfirmerie"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>

                <!-- Carte Commandes -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Commandes" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Fournisseurs" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button text="Gérer" onAction="#versCommandes"
                            style="-fx-background-color: #27ae60; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>

                <!-- Carte Fournisseurs -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Fournisseurs" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Stock / Produits" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button fx:id="fournisseursButton" text="Gérer" onAction="#versFournisseursProduits"
                            style="-fx-background-color: #9b59b6; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>
            </HBox>

            <!-- Zone d'accès rapide - Ligne 2 -->
            <HBox spacing="30" alignment="CENTER">
                <!-- Carte Catalogue Produits -->
                <VBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 30; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 200;">
                    <Text text="Catalogue" style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Produits commandables" style="-fx-font-size: 11px; -fx-fill: #bdc3c7;" />
                    <Button text="Gérer" onAction="#versFicheProduit"
                            style="-fx-background-color: #27ae60; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-background-radius: 20; -fx-cursor: hand;" />
                </VBox>
            </HBox>

            <!-- Pied de page -->
            <VBox spacing="5" alignment="CENTER">
                <Text text="Version 1.0 | 2025"
                      style="-fx-font-size: 12px; -fx-fill: #95a5a6;" />
                <Text text="© Tous droits réservés - HSP"
                      style="-fx-font-size: 12px; -fx-fill: #95a5a6;" />
            </VBox>
        </VBox>
    </center>

</BorderPane>
