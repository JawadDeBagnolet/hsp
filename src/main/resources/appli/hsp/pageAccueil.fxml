<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.PageAccueil"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;"
              alignment="CENTER_LEFT">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <!-- Logo -->
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <!-- Infos utilisateur connecté -->
            <VBox spacing="2" alignment="CENTER_RIGHT" style="-fx-padding: 0 20 0 0;">
                <Label fx:id="labelBienvenue" text="" style="-fx-text-fill: #e2e8f0; -fx-font-size: 12px; -fx-font-weight: bold;" />
                <Label fx:id="labelRole" text="" style="-fx-text-fill: #818cf8; -fx-font-size: 11px;" />
            </VBox>

            <!-- Navigation -->
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 7 14; -fx-font-weight: bold;"
                        onAction="#versAccueil" />
                <Button fx:id="btnSecretariat" text="Secrétariat"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versPatients" />
                <Button fx:id="btnDossiers" text="Dossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versDossiers" />
                <Button fx:id="btnTickets" text="Tickets"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versTickets" />
                <Button fx:id="btnInfirmerie" text="Infirmerie"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versVisiteInfirmerie" />
                <Button fx:id="btnCommandes" text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versCommandes" />
                <Button fx:id="btnPlanning" text="Planning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versPlanning" />
                <Button fx:id="btnCatalogue" text="Catalogue"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versFicheProduit" />
                <Button fx:id="btnFournisseurs" text="Fournisseurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versFournisseurs" />
                <Button fx:id="btnUtilisateurs" text="Utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versUtilisateurs" />
                <Button fx:id="btnDemandes" text="Mes Demandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 7 10;"
                        onAction="#versDemandes" />
                <Button text="Mon espace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 12px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 7 14;"
                        onAction="#versMonEspace" />
                <Button text="Déconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 7 14;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox alignment="CENTER" spacing="50" style="-fx-padding: 60 80;">

                <!-- Header -->
                <VBox spacing="10" alignment="CENTER">
                    <Text text="Tableau de bord"
                          style="-fx-font-size: 42px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Bienvenue dans votre espace de travail"
                          style="-fx-font-size: 16px; -fx-fill: #94a3b8;" />
                </VBox>

                <!-- Ligne 1 : Secrétariat · Planning · Infirmerie · Commandes · Fournisseurs -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Secrétariat — ADMIN, SECRETAIRE -->
                    <VBox fx:id="cardSecretariat" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(59,130,246,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(59,130,246,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Secrétariat" style="-fx-font-size: 18px; -fx-fill: #60a5fa; -fx-font-weight: bold;" />
                        <Text text="Inscription élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versPatients"
                                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Planning — ADMIN, SECRETAIRE -->
                    <VBox fx:id="cardPlanning" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(245,158,11,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(245,158,11,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Planning" style="-fx-font-size: 18px; -fx-fill: #fbbf24; -fx-font-weight: bold;" />
                        <Text text="RDV profs / élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Voir" onAction="#versPlanning"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Infirmerie — ADMIN, INFIRMIER, SECRETAIRE -->
                    <VBox fx:id="cardInfirmerie" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(239,68,68,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(239,68,68,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Infirmerie" style="-fx-font-size: 18px; -fx-fill: #f87171; -fx-font-weight: bold;" />
                        <Text text="Visites élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versVisiteInfirmerie"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Commandes — ADMIN, GESTIONNAIRE_DE_STOCK -->
                    <VBox fx:id="cardCommandes" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(16,185,129,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(16,185,129,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Commandes" style="-fx-font-size: 18px; -fx-fill: #34d399; -fx-font-weight: bold;" />
                        <Text text="Bons de commande" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versCommandes"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Fournisseurs — ADMIN, GESTIONNAIRE_DE_STOCK -->
                    <VBox fx:id="cardFournisseurs" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(139,92,246,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(139,92,246,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Fournisseurs" style="-fx-font-size: 18px; -fx-fill: #a78bfa; -fx-font-weight: bold;" />
                        <Text text="Gérer les fournisseurs" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versFournisseurs"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                </HBox>

                <!-- Ligne 2 : Catalogue · Tickets · Dossiers · Demandes produits -->
                <HBox spacing="20" alignment="CENTER">

                    <!-- Demandes produits — ADMIN, INFIRMIER -->
                    <VBox fx:id="cardDemandes" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(99,102,241,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(99,102,241,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Mes Demandes" style="-fx-font-size: 18px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                        <Text text="Demander des produits" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Accéder" onAction="#versDemandes"
                                style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Catalogue — ADMIN, GESTIONNAIRE_DE_STOCK -->
                    <VBox fx:id="cardCatalogue" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(6,182,212,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(6,182,212,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Catalogue" style="-fx-font-size: 18px; -fx-fill: #22d3ee; -fx-font-weight: bold;" />
                        <Text text="Produits commandables" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versFicheProduit"
                                style="-fx-background-color: #06b6d4; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Tickets — ADMIN, INFIRMIER, SECRETAIRE -->
                    <VBox fx:id="cardTickets" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(251,146,60,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(251,146,60,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Tickets" style="-fx-font-size: 18px; -fx-fill: #fb923c; -fx-font-weight: bold;" />
                        <Text text="Envoi en infirmerie" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versTickets"
                                style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                    <!-- Dossiers — ADMIN, INFIRMIER, SECRETAIRE -->
                    <VBox fx:id="cardDossiers" spacing="14" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(236,72,153,0.1); -fx-padding: 28; -fx-background-radius: 16; -fx-border-color: rgba(236,72,153,0.35); -fx-border-width: 1; -fx-border-radius: 16; -fx-pref-width: 200; -fx-min-height: 160;">
                        <Text text="Dossiers" style="-fx-font-size: 18px; -fx-fill: #f472b6; -fx-font-weight: bold;" />
                        <Text text="Rapports élèves" style="-fx-font-size: 12px; -fx-fill: #64748b;" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button text="Gérer" onAction="#versDossiers"
                                style="-fx-background-color: #ec4899; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 7 24;" />
                    </VBox>

                </HBox>

                <!-- Footer -->
                <VBox spacing="4" alignment="CENTER">
                    <Text text="Version 1.0 · 2025" style="-fx-font-size: 12px; -fx-fill: #334155;" />
                    <Text text="© LPRS - Lycée de Santé Publique" style="-fx-font-size: 12px; -fx-fill: #334155;" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
