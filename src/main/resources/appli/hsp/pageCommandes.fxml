<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="appli.hsp.PageCommandes"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;"/>
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;"/>
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Commandes"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;"/>
                <Button text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;"/>
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;"/>
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;"/>
            </HBox>
        </HBox>
    </top>

    <!-- Zone principale -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 30;">

                <!-- Titre -->
                <VBox spacing="4">
                    <Text text="Gestion des commandes" style="-fx-font-size: 26px; -fx-fill: #ffffff; -fx-font-weight: bold;"/>
                    <Text text="Gérez les demandes des infirmiers et les commandes aux fournisseurs"
                          style="-fx-font-size: 13px; -fx-fill: #94a3b8;"/>
                </VBox>

                <!-- TabPane -->
                <TabPane tabClosingPolicy="UNAVAILABLE">

                    <!-- ===== ONGLET 1 : Demandes infirmiers ===== -->
                    <Tab text="Demandes des infirmiers">
                        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: rgba(30,41,59,0.5); -fx-background-radius: 0 10 10 10; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 0 1 1 1; -fx-border-radius: 0 10 10 10;">

                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Text text="Demandes de produits en attente" style="-fx-font-size: 16px; -fx-fill: #ffffff; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                                <Button text="Rafraichir" onAction="#handleRafraichirDemandes"
                                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16;"/>
                            </HBox>

                            <TableView fx:id="demandesTable" prefHeight="400" VBox.vgrow="ALWAYS"
                                       style="-fx-background-color: rgba(248,250,252,0.97); -fx-border-color: rgba(99,102,241,0.2); -fx-border-radius: 6; -fx-background-radius: 6;">
                                <columns>
                                    <TableColumn fx:id="demIdCol" prefWidth="60" text="ID"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                    <TableColumn fx:id="demDateCol" prefWidth="160" text="Date"
                                                 style="-fx-font-weight: bold;"/>
                                    <TableColumn fx:id="demInfirmierCol" prefWidth="180" text="Infirmier"
                                                 style="-fx-font-weight: bold;"/>
                                    <TableColumn fx:id="demQuantiteCol" prefWidth="90" text="Quantité"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                    <TableColumn fx:id="demStatutCol" prefWidth="110" text="Statut"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                    <TableColumn fx:id="demActionsCol" prefWidth="160" text="Action"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                </columns>
                                <placeholder>
                                    <Label text="Aucune demande" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                </placeholder>
                            </TableView>

                            <Label text="Cliquez sur 'Creer commande' pour transformer une demande en commande fournisseur."
                                   style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-style: italic;"/>
                        </VBox>
                    </Tab>

                    <!-- ===== ONGLET 2 : Commandes fournisseurs ===== -->
                    <Tab text="Commandes fournisseurs">
                        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: rgba(30,41,59,0.5); -fx-background-radius: 0 10 10 10; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 0 1 1 1; -fx-border-radius: 0 10 10 10;">

                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <Text text="Commandes envoyees aux fournisseurs" style="-fx-font-size: 16px; -fx-fill: #ffffff; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                                <Button text="Rafraichir" onAction="#handleRafraichirCommandes"
                                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 7 16;"/>
                            </HBox>

                            <TableView fx:id="commandesTable" prefHeight="400" VBox.vgrow="ALWAYS"
                                       style="-fx-background-color: rgba(248,250,252,0.97); -fx-border-color: rgba(99,102,241,0.2); -fx-border-radius: 6; -fx-background-radius: 6;">
                                <columns>
                                    <TableColumn fx:id="cmdIdCol" prefWidth="60" text="ID"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                    <TableColumn fx:id="cmdDateCol" prefWidth="155" text="Date"
                                                 style="-fx-font-weight: bold;"/>
                                    <TableColumn fx:id="cmdFournisseurCol" prefWidth="155" text="Fournisseur"
                                                 style="-fx-font-weight: bold;"/>
                                    <TableColumn fx:id="cmdLibelleCol" prefWidth="215" text="Libelle"
                                                 style="-fx-font-weight: bold;"/>
                                    <TableColumn fx:id="cmdStatutCol" prefWidth="110" text="Statut"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                    <TableColumn fx:id="cmdActionsCol" prefWidth="160" text="Actions"
                                                 style="-fx-font-weight: bold; -fx-alignment: CENTER;"/>
                                </columns>
                                <placeholder>
                                    <Label text="Aucune commande enregistree" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
                                </placeholder>
                            </TableView>
                        </VBox>
                    </Tab>

                </TabPane>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
