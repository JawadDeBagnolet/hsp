<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.PageUtilisateurs"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>
            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDossiers" text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavPlanning" text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavCatalogue" text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background: transparent; -fx-border-color: transparent; -fx-background-color: transparent;">
            <VBox spacing="25" style="-fx-padding: 30;">

            <!-- En-tête avec recherche -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Text text="Gestion des Utilisateurs"
                          style="-fx-font-size: 36px; -fx-fill: #ffffff; -fx-font-weight: bold; -fx-font-family: 'Arial Black';" />
                    <Text fx:id="totalUsersLabel" text="Total: 0 utilisateurs"
                          style="-fx-font-size: 13px; -fx-fill: #ecf0f1;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="rechercheField"
                           promptText="Rechercher..."
                           prefWidth="280"
                           style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 10; -fx-border-color: transparent; -fx-prompt-text-fill: #64748b; -fx-font-size: 13px;" />
            </HBox>

            <!-- Filtres -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 15 20; -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10;">
                <Text text="Filtrer:"
                      style="-fx-font-size: 13px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                <Button text="Tous" onAction="#afficherTous"
                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16;" />
                <Button text="Admin" onAction="#filtrerParRole" userData="ADMIN"
                        style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16; -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;" />
                <Button text="Médecin" onAction="#filtrerParRole" userData="MEDECIN"
                        style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16; -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;" />
                <Button text="Infirmier" onAction="#filtrerParRole" userData="INFIRMIER"
                        style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16; -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;" />
                <Button text="Secrétaire" onAction="#filtrerParRole" userData="SECRETAIRE"
                        style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16; -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;" />
                <Button text="Stock" onAction="#filtrerParRole" userData="GESTIONNAIRE_DE_STOCK"
                        style="-fx-background-color: rgba(255, 255, 255, 0.2); -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-border-radius: 20; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 16; -fx-border-color: rgba(255,255,255,0.4); -fx-border-width: 1;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="↻ Actualiser" onAction="#chargerUtilisateurs"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 12px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;" />
                <Button text="🧪 Test" onAction="#chargerUtilisateursTest"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 12px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;" />
            </HBox>

            <!-- Liste des utilisateurs -->
            <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 25; -fx-background-radius: 12; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 12;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Text text="👥 Liste des utilisateurs"
                          style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Text fx:id="resultCountLabel" text=""
                          style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
                </HBox>

                <VBox fx:id="utilisateursContainer" spacing="5"
                          prefHeight="400"
                          style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10;" />
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="20" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 25; -fx-background-radius: 12; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 12;">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Text text="✏️ Formulaire"
                          style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Text fx:id="formModeLabel" text="Mode: Ajout"
                          style="-fx-font-size: 12px; -fx-fill: #ecf0f1; -fx-font-style: italic;" />
                </HBox>

                <GridPane hgap="20" vgap="15">
                    <Label text="Nom*" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                               style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5; -fx-border-color: transparent; -fx-font-size: 13px;" />

                    <Label text="Prénom*" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5; -fx-border-color: transparent; -fx-font-size: 13px;" />

                    <Label text="Email*" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                               style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5; -fx-border-color: transparent; -fx-font-size: 13px;" />

                    <Label text="Mot de passe" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <PasswordField fx:id="mdpField" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                  promptText="Laisser vide pour ne pas modifier"
                                  style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5; -fx-border-color: transparent; -fx-font-size: 13px;" />

                    <Label text="Rôle*" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ffffff;" />
                    <ComboBox fx:id="roleComboBox" GridPane.rowIndex="4" GridPane.columnIndex="1"
                              style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5; -fx-border-color: transparent; -fx-font-size: 13px;" />
                </GridPane>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="ajouterButton" text="➕ Ajouter" onAction="#ajouterUtilisateur"
                            style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
                    <Button fx:id="modifierButton" text="✏️ Modifier" onAction="#modifierUtilisateur" disable="true"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 13px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
                    <Button fx:id="supprimerButton" text="🗑️ Supprimer" onAction="#supprimerUtilisateur" disable="true"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="viderButton" text="↻ Vider" onAction="#viderChamps"
                            style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-size: 13px; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 10 20; -fx-font-weight: bold;" />
                </HBox>
            </VBox>

            <!-- Message -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 15 20; -fx-background-radius: 8; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 8;">
                <Text text="ℹ" style="-fx-font-size: 16px; -fx-fill: #ecf0f1;" />
                <Label fx:id="messageLabel"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-wrap-text: true; -fx-text-fill: #ecf0f1;" />
            </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
