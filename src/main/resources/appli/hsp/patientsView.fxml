<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.PatientsController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation en haut -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS"
                      style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique"
                      style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Secrétariat"
                        style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button text="Dossiers" onAction="#versDossiers"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Planning" onAction="#versPlanning"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Catalogue" onAction="#versFicheProduit"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Utilisateurs" onAction="#versUtilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <!-- Panneau gauche : Liste des élèves -->
            <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
                <children>
                    <VBox spacing="10" alignment="CENTER">
                        <Text text="Liste des Élèves" style="-fx-font-size: 24px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                        <Text text="Gestion des inscriptions élèves" style="-fx-font-size: 14px; -fx-fill: #ecf0f1;" />

                        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0;">
                            <VBox spacing="5" alignment="CENTER" style="-fx-background-color: rgba(52, 152, 219, 0.2); -fx-padding: 10; -fx-background-radius: 10;">
                                <Text text="Total" style="-fx-font-size: 12px; -fx-fill: #ffffff;" />
                                <Label fx:id="totalPatientsLabel" text="0" style="-fx-font-size: 20px; -fx-fill: #3b82f6; -fx-font-weight: bold;" />
                            </VBox>
                            <Button text="Actualiser" onAction="#handleRefresh"
                                    style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 20; -fx-cursor: hand;" />
                        </HBox>
                    </VBox>

                    <TextField fx:id="rechercheField" promptText="Rechercher un élève..."
                              onKeyTyped="#rechercherPatients"
                              style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 10; -fx-border-color: transparent; -fx-prompt-text-fill: #64748b; -fx-font-size: 14px;" />

                    <ListView fx:id="patientsListView" prefHeight="400" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10;" />
                </children>
            </VBox>

            <!-- Panneau droit : Formulaire -->
            <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 370;">
                <children>
                    <VBox spacing="5" alignment="CENTER">
                        <Text text="Fiche Élève" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                        <Text text="Ajouter ou modifier un élève" style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
                    </VBox>

                    <Label fx:id="messageLabel" text="Prêt" style="-fx-text-fill: #3b82f6; -fx-font-size: 12px; -fx-font-weight: bold; -fx-wrap-text: true;" />

                    <GridPane hgap="10" vgap="10">
                        <children>
                            <Label text="Nom:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <TextField fx:id="nomField" promptText="Nom de l'élève" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                            <Label text="Prénom:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <TextField fx:id="prenomField" promptText="Prénom de l'élève" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                            <Label text="N° Étudiant:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <TextField fx:id="numEtudiantField" promptText="Numéro étudiant" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                            <Label text="Email:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                            <TextField fx:id="emailField" promptText="Email de l'élève" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                            <Label text="Téléphone:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                            <TextField fx:id="telField" promptText="Numéro de téléphone" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                            <Label text="Rue:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                            <TextField fx:id="rueField" promptText="Adresse" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="5" GridPane.columnIndex="1" />

                            <Label text="Code Postal:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                            <TextField fx:id="cpField" promptText="Code postal" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="6" GridPane.columnIndex="1" />

                            <Label text="Ville:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="7" GridPane.columnIndex="0" />
                            <TextField fx:id="villeField" promptText="Ville" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="7" GridPane.columnIndex="1" />

                            <Label text="Candidature:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="8" GridPane.columnIndex="0" />
                            <ComboBox fx:id="candidatureComboBox" style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;" GridPane.rowIndex="8" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />
                        </children>
                    </GridPane>

                    <VBox spacing="10">
                        <Button fx:id="ajouterButton" text="Ajouter Élève" onAction="#ajouterPatient"
                                style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />

                        <HBox spacing="10">
                            <Button fx:id="modifierButton" text="Modifier" onAction="#modifierPatient"
                                    style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />

                            <Button fx:id="supprimerButton" text="Supprimer" onAction="#supprimerPatient"
                                    style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />
                        </HBox>

                        <Button fx:id="viderButton" text="Vider Formulaire" onAction="#viderChamps"
                                style="-fx-background-color: #64748b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />
                    </VBox>
                </children>
            </VBox>
        </HBox>
    </center>
</BorderPane>
