<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.VisiteInfirmerieController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="14" right="28" bottom="14" left="28"/></padding>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavSecretariat" text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Infirmerie"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button fx:id="btnNavCommandes" text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button fx:id="btnNavDemandes" text="Mes Demandes" onAction="#versDemandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- ══ Panneau gauche : tableau + filtres ══ -->
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: rgba(30,41,59,0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 1; -fx-border-radius: 15;">

                <!-- Titre + compteur -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <Text text="Visites Infirmerie" style="-fx-font-size: 22px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                        <Text text="Suivi des passages élèves" style="-fx-font-size: 13px; -fx-fill: #94a3b8;" />
                    </VBox>
                    <VBox spacing="3" alignment="CENTER"
                          style="-fx-background-color: rgba(52,152,219,0.2); -fx-padding: 10 18; -fx-background-radius: 10;">
                        <Text text="Total" style="-fx-font-size: 11px; -fx-fill: #94a3b8;" />
                        <Label fx:id="totalVisitesLabel" text="0"
                               style="-fx-font-size: 22px; -fx-text-fill: #3b82f6; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

                <!-- Filtre par date -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Text text="Date :" style="-fx-fill: #cbd5e1; -fx-font-size: 12px;" />
                    <DatePicker fx:id="filtreDate" prefWidth="140"
                                style="-fx-background-radius: 5;" />
                    <Button text="Filtrer" onAction="#filtrerParDate"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;" />
                </HBox>

                <!-- Filtre par élève (point 4) -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Text text="Élève :" style="-fx-fill: #cbd5e1; -fx-font-size: 12px;" />
                    <ComboBox fx:id="filtreEleveCombo" prefWidth="220"
                              style="-fx-background-radius: 5;" />
                    <Button text="Filtrer" onAction="#filtrerParEleve"
                            style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;" />
                    <Button text="Tout afficher" onAction="#toutAfficher"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 6 12;" />
                </HBox>

                <!-- TableView (point 6) -->
                <TableView fx:id="visitesTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 6;">
                    <columns>
                        <TableColumn fx:id="colId"         text="ID"          prefWidth="48"  />
                        <TableColumn fx:id="colEleve"      text="Élève"        prefWidth="165" />
                        <TableColumn fx:id="colDate"       text="Date"         prefWidth="95"  />
                        <TableColumn fx:id="colHeure"      text="Heure"        prefWidth="65"  />
                        <TableColumn fx:id="colMotif"      text="Motif"        prefWidth="145" />
                        <TableColumn fx:id="colTraitement" text="Traitement"   prefWidth="145" />
                        <TableColumn fx:id="colStatut"     text="Statut"       prefWidth="100" />
                    </columns>
                    <placeholder>
                        <Label text="Aucune visite enregistrée"
                               style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                    </placeholder>
                </TableView>

            </VBox>

            <!-- ══ Panneau droit : formulaire ══ -->
            <VBox spacing="14" prefWidth="390"
                  style="-fx-background-color: rgba(30,41,59,0.5); -fx-padding: 22; -fx-background-radius: 15; -fx-border-color: rgba(99,102,241,0.2); -fx-border-width: 1; -fx-border-radius: 15;">

                <VBox spacing="4" alignment="CENTER">
                    <Text text="Enregistrer une Visite"
                          style="-fx-font-size: 18px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Renseignez les informations du passage"
                          style="-fx-font-size: 12px; -fx-fill: #94a3b8;" />
                </VBox>

                <Label fx:id="messageLabel" text="Prêt"
                       style="-fx-text-fill: #3b82f6; -fx-font-size: 12px; -fx-font-weight: bold; -fx-wrap-text: true;" />

                <!-- Champs formulaire -->
                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <Label text="Élève :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <ComboBox fx:id="eleveComboBox" promptText="Sélectionner un élève"
                              style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                              maxWidth="1.7976931348623157E308"
                              GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Date :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <DatePicker fx:id="datePicker"
                                style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                                maxWidth="1.7976931348623157E308"
                                GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="Heure (HH:mm) :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <TextField fx:id="heureField" promptText="ex: 09:30"
                               style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                               GridPane.rowIndex="2" GridPane.columnIndex="1" />

                    <Label text="Motif :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="3" GridPane.columnIndex="0" />
                    <TextField fx:id="motifField" promptText="Motif de la visite"
                               style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                               GridPane.rowIndex="3" GridPane.columnIndex="1" />

                    <!-- Point 1 : traitement dispensé -->
                    <Label text="Traitement :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.valignment="TOP" />
                    <TextArea fx:id="traitementArea" promptText="Soins dispensés, médicaments donnés…"
                              prefRowCount="3"
                              style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                              GridPane.rowIndex="4" GridPane.columnIndex="1" />

                    <!-- Point 5 : statut de la visite -->
                    <Label text="Statut :" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0" />
                    <ComboBox fx:id="statutCombo"
                              style="-fx-background-color: rgba(248,250,252,0.95); -fx-background-radius: 5;"
                              maxWidth="1.7976931348623157E308"
                              GridPane.rowIndex="5" GridPane.columnIndex="1" />
                </GridPane>

                <!-- Boutons -->
                <VBox spacing="10">
                    <Button fx:id="ajouterButton" text="Enregistrer la Visite" onAction="#ajouterVisite"
                            style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand;"
                            maxWidth="1.7976931348623157E308" />

                    <HBox spacing="10">
                        <Button fx:id="modifierButton" text="Modifier" onAction="#modifierVisite"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;"
                                HBox.hgrow="ALWAYS" disable="true" />
                        <Button fx:id="supprimerButton" text="Supprimer" onAction="#supprimerVisite"
                                style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;"
                                HBox.hgrow="ALWAYS" disable="true" />
                    </HBox>

                    <Button text="Vider Formulaire" onAction="#viderChamps"
                            style="-fx-background-color: #64748b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;"
                            maxWidth="1.7976931348623157E308" />
                </VBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>
