<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.VisiteInfirmerieController"
            style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #3498db);">

    <!-- Barre de navigation -->
    <top>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 15; -fx-border-color: #2c3e50; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Text text="HSP" style="-fx-font-size: 24px; -fx-fill: #3498db; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
            </VBox>

            <HBox spacing="20" alignment="CENTER">
                <Button text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versAccueil" />
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                <Button text="Secrétariat"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versPatients" />
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                <Button text="Infirmerie"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #c0392b; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" />
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                <Button text="Commandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versCommandes" />
                <Separator orientation="VERTICAL" style="-fx-background-color: #7f8c8d;" />
                <Button text="Mon espace"
                        style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 14px; -fx-border-color: transparent; -fx-cursor: hand;"
                        onAction="#versMonEspace" />
                <Button text="Déconnexion"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-border-color: #c0392b; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;"
                        onAction="#deconnexion" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- Panneau gauche : Liste des visites -->
            <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.3); -fx-border-width: 1; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">

                <VBox spacing="10" alignment="CENTER">
                    <Text text="Visites Infirmerie" style="-fx-font-size: 24px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Suivi des passages élèves" style="-fx-font-size: 14px; -fx-fill: #ecf0f1;" />

                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0;">
                        <VBox spacing="5" alignment="CENTER" style="-fx-background-color: rgba(52,152,219,0.2); -fx-padding: 10; -fx-background-radius: 10;">
                            <Text text="Total" style="-fx-font-size: 12px; -fx-fill: #ffffff;" />
                            <Label fx:id="totalVisitesLabel" text="0" style="-fx-font-size: 20px; -fx-fill: #3498db; -fx-font-weight: bold;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Filtre par date -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Text text="Filtrer par date:" style="-fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <DatePicker fx:id="filtreDate" style="-fx-background-radius: 5;" />
                    <Button fx:id="filtrerButton" text="Filtrer" onAction="#filtrerParDate"
                            style="-fx-background-color: #f39c12; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="toutAfficherButton" text="Tout afficher" onAction="#toutAfficher"
                            style="-fx-background-color: #3498db; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;" />
                </HBox>

                <ListView fx:id="visitesListView" prefHeight="450" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.3); -fx-border-width: 1; -fx-border-radius: 10;" />
            </VBox>

            <!-- Panneau droit : Formulaire -->
            <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(255,255,255,0.3); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 350;">

                <VBox spacing="5" alignment="CENTER">
                    <Text text="Enregistrer une Visite" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Quel élève, quel jour, à quelle heure" style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
                </VBox>

                <Label fx:id="messageLabel" text="Prêt" style="-fx-text-fill: #3498db; -fx-font-size: 12px; -fx-font-weight: bold; -fx-wrap-text: true;" />

                <GridPane hgap="10" vgap="12">
                    <children>
                        <Label text="Élève:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <ComboBox fx:id="eleveComboBox" promptText="Sélectionner un élève"
                                  style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 5;"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />

                        <Label text="Date:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <DatePicker fx:id="datePicker"
                                    style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 5;"
                                    GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />

                        <Label text="Heure (HH:mm):" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="heureField" promptText="ex: 09:30"
                                   style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 5;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1" />

                        <Label text="Motif:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextField fx:id="motifField" promptText="Motif de la visite (optionnel)"
                                   style="-fx-background-color: rgba(255,255,255,0.9); -fx-background-radius: 5;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1" />
                    </children>
                </GridPane>

                <VBox spacing="10">
                    <Button fx:id="ajouterButton" text="Enregistrer la Visite" onAction="#ajouterVisite"
                            style="-fx-background-color: #27ae60; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />

                    <HBox spacing="10">
                        <Button fx:id="modifierButton" text="Modifier" onAction="#modifierVisite"
                                style="-fx-background-color: #f39c12; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />
                        <Button fx:id="supprimerButton" text="Supprimer" onAction="#supprimerVisite"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />
                    </HBox>

                    <Button fx:id="viderButton" text="Vider Formulaire" onAction="#viderChamps"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />
                </VBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>
