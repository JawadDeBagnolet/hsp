<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="appli.hsp.VisiteInfirmerieController"
            style="-fx-background-color: linear-gradient(to bottom, #0f172a, #1e1b4b);">

    <!-- Barre de navigation -->
    <top>
        <HBox style="-fx-background-color: #080c14; -fx-border-color: #6366f1; -fx-border-width: 0 0 2 0;">
            <padding>
                <Insets top="14" right="28" bottom="14" left="28"/>
            </padding>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Text text="LPRS" style="-fx-font-size: 22px; -fx-fill: #818cf8; -fx-font-weight: bold;" />
                <Text text="Lycée de Santé Publique" style="-fx-font-size: 11px; -fx-fill: #64748b;" />
            </VBox>

            <HBox spacing="4" alignment="CENTER">
                <Button text="Accueil" onAction="#versAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Secrétariat" onAction="#versPatients"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Infirmerie"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18; -fx-font-weight: bold;" />
                <Button text="Commandes" onAction="#versCommandes"
                        style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-border-color: transparent; -fx-cursor: hand; -fx-padding: 8 14;" />
                <Button text="Mon espace" onAction="#versMonEspace"
                        style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: rgba(99,102,241,0.5); -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 8 18;" />
                <Button text="Déconnexion" onAction="#deconnexion"
                        style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 13px; -fx-background-radius: 20; -fx-border-radius: 20; -fx-cursor: hand; -fx-padding: 8 18;" />
            </HBox>
        </HBox>
    </top>

    <!-- Contenu principal -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- Panneau gauche : Liste des visites -->
            <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">

                <VBox spacing="10" alignment="CENTER">
                    <Text text="Visites Infirmerie" style="-fx-font-size: 24px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Suivi des passages élèves" style="-fx-font-size: 14px; -fx-fill: #ecf0f1;" />

                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0;">
                        <VBox spacing="5" alignment="CENTER" style="-fx-background-color: rgba(52,152,219,0.2); -fx-padding: 10; -fx-background-radius: 10;">
                            <Text text="Total" style="-fx-font-size: 12px; -fx-fill: #ffffff;" />
                            <Label fx:id="totalVisitesLabel" text="0" style="-fx-font-size: 20px; -fx-fill: #3b82f6; -fx-font-weight: bold;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Filtre par date -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Text text="Filtrer par date:" style="-fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <DatePicker fx:id="filtreDate" style="-fx-background-radius: 5;" />
                    <Button fx:id="filtrerButton" text="Filtrer" onAction="#filtrerParDate"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;" />
                    <Button fx:id="toutAfficherButton" text="Tout afficher" onAction="#toutAfficher"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-background-radius: 8; -fx-cursor: hand;" />
                </HBox>

                <ListView fx:id="visitesListView" prefHeight="450" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: rgba(248, 250, 252, 0.97); -fx-background-radius: 10; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 10;" />
            </VBox>

            <!-- Panneau droit : Formulaire -->
            <VBox spacing="15" style="-fx-background-color: rgba(30, 41, 59, 0.5); -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: rgba(99, 102, 241, 0.2); -fx-border-width: 1; -fx-border-radius: 15; -fx-pref-width: 350;">

                <VBox spacing="5" alignment="CENTER">
                    <Text text="Enregistrer une Visite" style="-fx-font-size: 20px; -fx-fill: #ffffff; -fx-font-weight: bold;" />
                    <Text text="Quel élève, quel jour, à quelle heure" style="-fx-font-size: 12px; -fx-fill: #ecf0f1;" />
                </VBox>

                <Label fx:id="messageLabel" text="Prêt" style="-fx-text-fill: #3b82f6; -fx-font-size: 12px; -fx-font-weight: bold; -fx-wrap-text: true;" />

                <GridPane hgap="10" vgap="12">
                    <children>
                        <Label text="Élève:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <ComboBox fx:id="eleveComboBox" promptText="Sélectionner un élève"
                                  style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />

                        <Label text="Date:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <DatePicker fx:id="datePicker"
                                    style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;"
                                    GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />

                        <Label text="Heure (HH:mm):" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <TextField fx:id="heureField" promptText="ex: 09:30"
                                   style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="1" />

                        <Label text="Motif:" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <TextField fx:id="motifField" promptText="Motif de la visite (optionnel)"
                                   style="-fx-background-color: rgba(248, 250, 252, 0.95); -fx-background-radius: 5;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="1" />
                    </children>
                </GridPane>

                <VBox spacing="10">
                    <Button fx:id="ajouterButton" text="Enregistrer la Visite" onAction="#ajouterVisite"
                            style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />

                    <HBox spacing="10">
                        <Button fx:id="modifierButton" text="Modifier" onAction="#modifierVisite"
                                style="-fx-background-color: #f59e0b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />
                        <Button fx:id="supprimerButton" text="Supprimer" onAction="#supprimerVisite"
                                style="-fx-background-color: #ef4444; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" HBox.hgrow="ALWAYS" disable="true" />
                    </HBox>

                    <Button fx:id="viderButton" text="Vider Formulaire" onAction="#viderChamps"
                            style="-fx-background-color: #64748b; -fx-text-fill: #ffffff; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 8; -fx-background-radius: 8; -fx-cursor: hand;" maxWidth="1.7976931348623157E308" />
                </VBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>
